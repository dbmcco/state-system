    "mission_runs": { "type": "array", "items": { "type": "object" } },
    "agent_runs": { "type": "array", "items": { "type": "object" } },
    "events": { "type": "array", "items": { "type": "object" } },
    "observations": { "type": "array", "items": { "type": "object" } },
    "findings": { "type": "array", "items": { "type": "object" } },
    "stumbles": { "type": "array", "items": { "type": "object" } },
    "artifacts": { "type": "array", "items": { "type": "object" } },
    "governance_receipts": { "type": "array", "items": { "type": "object" } },
    "commit_results": { "type": "array", "items": { "type": "object" } },
    "journal_entries": { "type": "array", "items": { "type": "object" } },
    "memory_entries": { "type": "array", "items": { "type": "object" } },
    "review_signals": { "type": "array", "items": { "type": "object" } }
  }
}
