{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://state-system.local/schemas/package-pressure-question.schema.json",
  "title": "PackagePressureQuestionRegistry",
  "type": "object",
  "required": ["id", "generated_at", "cases", "invariant"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^package_pressure_question_registry\\.[a-z0-9_.-]+$"
    },
    "generated_at": { "type": "string" },
    "description": { "type": "string" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    },
    "invariant": {
      "type": "object",
      "required": [
        "assertions_check_package_fields_not_answer_text",
        "private_corpora_not_required",
        "gap_visibility_is_tested"
      ],
      "properties": {
        "assertions_check_package_fields_not_answer_text": { "type": "boolean" },
        "private_corpora_not_required": { "type": "boolean" },
        "gap_visibility_is_tested": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "required": ["id", "status", "package_id", "question", "assertions"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^package_pressure_question\\.[a-z0-9_.-]+$"
        },
        "status": {
          "type": "string",
          "enum": ["ready", "planned"]
        },
        "package_id": { "type": "string" },
        "question": { "type": "string" },
        "intent": { "type": "string" },
        "assertions": {
          "type": "object",
          "properties": {
            "required_route_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_source_coverage_refs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_tool_refs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_tool_action_refs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_source_gap_refs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_open_question_fragments": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_federation_pack_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_remote_instance_refs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "materialization_false_for_pack_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_answer_policy_flags": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_source_status": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["connector_ref"],
                "properties": {
                  "connector_ref": { "type": "string" },
                  "access_status": { "type": "string" },
                  "freshness_status": { "type": "string" },
                  "understanding_status": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
