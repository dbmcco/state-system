{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://state-system.local/schemas/question-route-contract.schema.json",
  "title": "QuestionRouteContractRegistry",
  "type": "object",
  "required": ["id", "generated_at", "routes", "invariant"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^question_route_registry\\.[a-z0-9_.-]+$"
    },
    "generated_at": { "type": "string" },
    "description": { "type": "string" },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/question_route_contract" }
    },
    "invariant": {
      "type": "object",
      "required": [
        "routes_declare_source_coverage",
        "gap_behavior_is_visible",
        "federated_routes_declare_materialization_boundary"
      ],
      "properties": {
        "routes_declare_source_coverage": { "type": "boolean" },
        "gap_behavior_is_visible": { "type": "boolean" },
        "federated_routes_declare_materialization_boundary": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "question_route_contract": {
      "type": "object",
      "required": [
        "route_id",
        "intent",
        "applies_to",
        "source_order",
        "required_source_coverage",
        "required_tools",
        "fallback_policy",
        "answer_contract",
        "gap_behavior"
      ],
      "properties": {
        "route_id": { "type": "string" },
        "intent": { "type": "string" },
        "applies_to": {
          "type": "array",
          "items": { "type": "string" }
        },
        "module_modes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source_module_ref", "mode"],
            "properties": {
              "source_module_ref": { "type": "string" },
              "mode": { "type": "string" }
            }
          }
        },
        "source_order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_source_coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["coverage_ref", "connector_refs", "minimum_status"],
            "properties": {
              "coverage_ref": { "type": "string" },
              "connector_refs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "source_module_refs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "minimum_status": { "type": "string" }
            }
          }
        },
        "required_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional_external_context_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "federated_query": {
          "type": "object",
          "required": [
            "source_instance_ref",
            "query_surface_ref",
            "local_materialization"
          ],
          "properties": {
            "source_instance_ref": { "type": "string" },
            "query_surface_ref": { "type": "string" },
            "index_ref": { "type": "string" },
            "local_materialization": { "type": "boolean" },
            "boundaries": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "fallback_policy": {
          "type": "object",
          "required": ["policy", "repair_gate"],
          "properties": {
            "policy": { "type": "string" },
            "repair_gate": { "type": "string" },
            "external_context_rule": { "type": "string" },
            "fallback_tool_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "answer_contract": {
          "type": "object",
          "required": [
            "requires_evidence_refs",
            "requires_source_freshness_summary",
            "direct_evidence_vs_interpretation"
          ],
          "properties": {
            "requires_evidence_refs": { "type": "boolean" },
            "requires_source_freshness_summary": { "type": "boolean" },
            "direct_evidence_vs_interpretation": { "type": "boolean" },
            "subject_note_policy": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rules": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "gap_behavior": {
          "type": "object",
          "required": ["when_required_source_missing", "when_source_stale"],
          "properties": {
            "when_required_source_missing": { "type": "string" },
            "when_source_stale": { "type": "string" },
            "relevant_gap_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
