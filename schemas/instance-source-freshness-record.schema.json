{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://state-system.local/schemas/instance-source-freshness-record.schema.json",
  "title": "InstanceSourceFreshnessRecord",
  "type": "object",
  "required": [
    "id",
    "scope_key",
    "instance_ref",
    "connector_ref",
    "source_ref",
    "connector_type",
    "status",
    "checked_at",
    "source_watermark",
    "stale_after",
    "watermark_basis",
    "status_reason",
    "evidence_refs",
    "freshness_is_recency_evidence",
    "proves_live_access",
    "authorizes_execution",
    "protected_action_authorized_by"
  ],
  "properties": {
    "id": { "type": "string" },
    "scope_key": { "type": "string" },
    "instance_ref": { "type": "string" },
    "connector_ref": { "type": "string" },
    "source_ref": { "type": "string" },
    "connector_type": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["fresh", "stale", "failed", "unknown"]
    },
    "checked_at": { "type": "string" },
    "source_watermark": { "type": "string" },
    "stale_after": { "type": "string" },
    "watermark_basis": {
      "type": "string",
      "enum": [
        "source_content",
        "source_event",
        "source_index",
        "derived_index",
        "package_generation",
        "probe_only",
        "declared_gap"
      ]
    },
    "latest_source_event_at": { "type": "string" },
    "latest_source_modified_at": { "type": "string" },
    "latest_decision_updated_at": { "type": "string" },
    "latest_indexed_at": { "type": "string" },
    "source_item_count": {
      "type": "integer",
      "minimum": 0
    },
    "index_item_count": {
      "type": "integer",
      "minimum": 0
    },
    "freshness_policy_ref": { "type": "string" },
    "status_reason": { "type": "string" },
    "content_status": {
      "type": "string",
      "enum": ["fresh", "stale", "failed", "unknown"]
    },
    "event_status": {
      "type": "string",
      "enum": ["fresh", "stale", "failed", "unknown"]
    },
    "index_status": {
      "type": "string",
      "enum": ["fresh", "stale", "failed", "unknown"]
    },
    "probe_status": {
      "type": "string",
      "enum": ["fresh", "stale", "failed", "unknown"]
    },
    "completeness_status": {
      "type": "string",
      "enum": ["complete", "incomplete", "unknown", "not_applicable"]
    },
    "process_status": {
      "type": "string",
      "enum": ["succeeded", "failed", "running", "unknown"]
    },
    "source_gap_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "content_stale_after": { "type": "string" },
    "index_stale_after": { "type": "string" },
    "probe_stale_after": { "type": "string" },
    "lag_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "index_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "index_metadata": {
      "type": "object",
      "properties": {
        "owner": { "type": "string" },
        "backend": { "type": "string" },
        "status": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "error": {
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "detail": { "type": "string" },
    "freshness_is_recency_evidence": { "type": "boolean" },
    "proves_live_access": { "type": "boolean" },
    "authorizes_execution": { "type": "boolean" },
    "protected_action_authorized_by": { "type": "string" }
  }
}
