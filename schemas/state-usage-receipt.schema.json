{
  "$defs": {
    "RedactionPolicy": {
      "enum": [
        "none",
        "bounded",
        "hash_only"
      ],
      "title": "RedactionPolicy",
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "ephemeral",
        "operational",
        "audit"
      ],
      "title": "RetentionClass",
      "type": "string"
    },
    "StateOperation": {
      "enum": [
        "handshake",
        "inspect",
        "validate",
        "refresh",
        "search",
        "record",
        "repair",
        "acknowledge_gap"
      ],
      "title": "StateOperation",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "context_decision_ref": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Context Decision Ref"
    },
    "evidence_refs": {
      "items": {
        "maxLength": 512,
        "minLength": 3,
        "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "gap_refs": {
      "items": {
        "maxLength": 512,
        "minLength": 3,
        "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
        "type": "string"
      },
      "title": "Gap Refs",
      "type": "array"
    },
    "idempotency_key": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "operation": {
      "$ref": "#/$defs/StateOperation"
    },
    "package_ref": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Package Ref"
    },
    "protocol_version": {
      "const": "state-system.v1",
      "default": "state-system.v1",
      "title": "Protocol Version",
      "type": "string"
    },
    "receipt_id": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Receipt Id",
      "type": "string"
    },
    "redaction_policy": {
      "$ref": "#/$defs/RedactionPolicy"
    },
    "request_id": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Request Id",
      "type": "string"
    },
    "retain_until": {
      "format": "date-time",
      "title": "Retain Until",
      "type": "string"
    },
    "retention_class": {
      "$ref": "#/$defs/RetentionClass"
    },
    "used_at": {
      "format": "date-time",
      "title": "Used At",
      "type": "string"
    }
  },
  "required": [
    "idempotency_key",
    "retention_class",
    "retain_until",
    "redaction_policy",
    "receipt_id",
    "request_id",
    "operation",
    "used_at"
  ],
  "title": "StateUsageReceipt",
  "type": "object"
}
