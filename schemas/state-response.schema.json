{
  "$defs": {
    "FreshnessBasis": {
      "enum": [
        "source_content",
        "source_event",
        "source_index",
        "probe_only",
        "package_generation",
        "declared_gap"
      ],
      "title": "FreshnessBasis",
      "type": "string"
    },
    "FreshnessStatus": {
      "enum": [
        "fresh",
        "stale",
        "unknown",
        "failed",
        "not_applicable"
      ],
      "title": "FreshnessStatus",
      "type": "string"
    },
    "FreshnessSummary": {
      "additionalProperties": false,
      "description": "A declared freshness observation; this model does not calculate it.",
      "properties": {
        "basis": {
          "$ref": "#/$defs/FreshnessBasis"
        },
        "coverage_status": {
          "default": "unknown",
          "enum": [
            "complete",
            "partial",
            "unknown"
          ],
          "title": "Coverage Status",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 512,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "expires_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expires At"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "protocol_version": {
          "const": "state-system.v1",
          "default": "state-system.v1",
          "title": "Protocol Version",
          "type": "string"
        },
        "stale_after_seconds": {
          "anyOf": [
            {
              "maximum": 31536000,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stale After Seconds"
        },
        "status": {
          "$ref": "#/$defs/FreshnessStatus"
        },
        "status_reason": {
          "anyOf": [
            {
              "maxLength": 1000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status Reason"
        }
      },
      "required": [
        "status",
        "basis",
        "observed_at"
      ],
      "title": "FreshnessSummary",
      "type": "object"
    },
    "RedactionPolicy": {
      "enum": [
        "none",
        "bounded",
        "hash_only"
      ],
      "title": "RedactionPolicy",
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "ephemeral",
        "operational",
        "audit"
      ],
      "title": "RetentionClass",
      "type": "string"
    },
    "StateAuditLedgerEntry": {
      "additionalProperties": false,
      "properties": {
        "action_ref": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Action Ref"
        },
        "actor_ref": {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "title": "Actor Ref",
          "type": "string"
        },
        "authorization_ref": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Authorization Ref"
        },
        "entry_ref": {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "title": "Entry Ref",
          "type": "string"
        },
        "event_type": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^\\S+$",
          "title": "Event Type",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 512,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "idempotency_key": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^\\S+$",
          "title": "Idempotency Key",
          "type": "string"
        },
        "occurred_at": {
          "format": "date-time",
          "title": "Occurred At",
          "type": "string"
        },
        "outcome": {
          "$ref": "#/$defs/StateEffectStatus"
        },
        "protocol_version": {
          "const": "state-system.v1",
          "default": "state-system.v1",
          "title": "Protocol Version",
          "type": "string"
        },
        "redaction_policy": {
          "$ref": "#/$defs/RedactionPolicy"
        },
        "request_id": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^\\S+$",
          "title": "Request Id",
          "type": "string"
        },
        "retain_until": {
          "format": "date-time",
          "title": "Retain Until",
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        }
      },
      "required": [
        "idempotency_key",
        "retention_class",
        "retain_until",
        "redaction_policy",
        "entry_ref",
        "request_id",
        "event_type",
        "outcome",
        "occurred_at",
        "actor_ref"
      ],
      "title": "StateAuditLedgerEntry",
      "type": "object"
    },
    "StateEffectStatus": {
      "enum": [
        "allowed",
        "denied",
        "failed",
        "queued",
        "committed",
        "skipped"
      ],
      "title": "StateEffectStatus",
      "type": "string"
    },
    "StateError": {
      "additionalProperties": false,
      "description": "A safe, bounded repair error that never retains raw secret-like values.",
      "properties": {
        "blocking_refs": {
          "items": {
            "maxLength": 512,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
            "type": "string"
          },
          "title": "Blocking Refs",
          "type": "array"
        },
        "code": {
          "$ref": "#/$defs/StateErrorCode"
        },
        "expected_shape": {
          "anyOf": [
            {
              "maxLength": 1000,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Shape"
        },
        "field_path": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Field Path"
        },
        "message": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "next_steps": {
          "items": {
            "type": "string"
          },
          "maxItems": 8,
          "title": "Next Steps",
          "type": "array"
        },
        "protocol_version": {
          "const": "state-system.v1",
          "default": "state-system.v1",
          "title": "Protocol Version",
          "type": "string"
        },
        "received_value_redacted": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Received Value Redacted"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "safe_examples": {
          "items": {
            "type": "string"
          },
          "maxItems": 8,
          "title": "Safe Examples",
          "type": "array"
        },
        "schema_ref": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Ref"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "StateError",
      "type": "object"
    },
    "StateErrorCode": {
      "enum": [
        "invalid_request",
        "unknown_operation",
        "unsupported_version",
        "invalid_reference",
        "state_gap",
        "not_found",
        "unavailable",
        "conflict",
        "unauthorized",
        "governance_denied",
        "internal_error"
      ],
      "title": "StateErrorCode",
      "type": "string"
    },
    "StateExternalEffectReceipt": {
      "additionalProperties": false,
      "properties": {
        "action_ref": {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "title": "Action Ref",
          "type": "string"
        },
        "audit_entry_ref": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Audit Entry Ref"
        },
        "authorization_ref": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Authorization Ref"
        },
        "effect_ref": {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "title": "Effect Ref",
          "type": "string"
        },
        "error_ref": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Ref"
        },
        "idempotency_key": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^\\S+$",
          "title": "Idempotency Key",
          "type": "string"
        },
        "occurred_at": {
          "format": "date-time",
          "title": "Occurred At",
          "type": "string"
        },
        "protocol_version": {
          "const": "state-system.v1",
          "default": "state-system.v1",
          "title": "Protocol Version",
          "type": "string"
        },
        "provider_receipt_ref": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Receipt Ref"
        },
        "receipt_id": {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "title": "Receipt Id",
          "type": "string"
        },
        "redaction_policy": {
          "$ref": "#/$defs/RedactionPolicy"
        },
        "request_id": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^\\S+$",
          "title": "Request Id",
          "type": "string"
        },
        "retain_until": {
          "format": "date-time",
          "title": "Retain Until",
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "status": {
          "$ref": "#/$defs/StateEffectStatus"
        }
      },
      "required": [
        "idempotency_key",
        "retention_class",
        "retain_until",
        "redaction_policy",
        "receipt_id",
        "request_id",
        "effect_ref",
        "action_ref",
        "status",
        "occurred_at"
      ],
      "title": "StateExternalEffectReceipt",
      "type": "object"
    },
    "StateOperation": {
      "enum": [
        "handshake",
        "inspect",
        "validate",
        "refresh",
        "search",
        "record",
        "repair",
        "acknowledge_gap"
      ],
      "title": "StateOperation",
      "type": "string"
    },
    "StateResponseStatus": {
      "enum": [
        "ok",
        "partial",
        "error"
      ],
      "title": "StateResponseStatus",
      "type": "string"
    },
    "StateUsageReceipt": {
      "additionalProperties": false,
      "properties": {
        "context_decision_ref": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Context Decision Ref"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 512,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "gap_refs": {
          "items": {
            "maxLength": 512,
            "minLength": 3,
            "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
            "type": "string"
          },
          "title": "Gap Refs",
          "type": "array"
        },
        "idempotency_key": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^\\S+$",
          "title": "Idempotency Key",
          "type": "string"
        },
        "operation": {
          "$ref": "#/$defs/StateOperation"
        },
        "package_ref": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 3,
              "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Package Ref"
        },
        "protocol_version": {
          "const": "state-system.v1",
          "default": "state-system.v1",
          "title": "Protocol Version",
          "type": "string"
        },
        "receipt_id": {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "title": "Receipt Id",
          "type": "string"
        },
        "redaction_policy": {
          "$ref": "#/$defs/RedactionPolicy"
        },
        "request_id": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^\\S+$",
          "title": "Request Id",
          "type": "string"
        },
        "retain_until": {
          "format": "date-time",
          "title": "Retain Until",
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "used_at": {
          "format": "date-time",
          "title": "Used At",
          "type": "string"
        }
      },
      "required": [
        "idempotency_key",
        "retention_class",
        "retain_until",
        "redaction_policy",
        "receipt_id",
        "request_id",
        "operation",
        "used_at"
      ],
      "title": "StateUsageReceipt",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "data": {
      "additionalProperties": true,
      "title": "Data",
      "type": "object"
    },
    "errors": {
      "items": {
        "$ref": "#/$defs/StateError"
      },
      "maxItems": 32,
      "title": "Errors",
      "type": "array"
    },
    "evidence_refs": {
      "items": {
        "maxLength": 512,
        "minLength": 3,
        "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "freshness": {
      "anyOf": [
        {
          "$ref": "#/$defs/FreshnessSummary"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "gap_refs": {
      "items": {
        "maxLength": 512,
        "minLength": 3,
        "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
        "type": "string"
      },
      "title": "Gap Refs",
      "type": "array"
    },
    "next_steps": {
      "items": {
        "type": "string"
      },
      "maxItems": 8,
      "title": "Next Steps",
      "type": "array"
    },
    "operation": {
      "$ref": "#/$defs/StateOperation"
    },
    "protocol_version": {
      "const": "state-system.v1",
      "default": "state-system.v1",
      "title": "Protocol Version",
      "type": "string"
    },
    "receipt": {
      "anyOf": [
        {
          "$ref": "#/$defs/StateUsageReceipt"
        },
        {
          "$ref": "#/$defs/StateExternalEffectReceipt"
        },
        {
          "$ref": "#/$defs/StateAuditLedgerEntry"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Receipt"
    },
    "receipt_ref": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Receipt Ref"
    },
    "request_id": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Request Id",
      "type": "string"
    },
    "retryable": {
      "default": false,
      "title": "Retryable",
      "type": "boolean"
    },
    "status": {
      "$ref": "#/$defs/StateResponseStatus"
    }
  },
  "required": [
    "request_id",
    "operation",
    "status"
  ],
  "title": "StateResponse",
  "type": "object"
}
