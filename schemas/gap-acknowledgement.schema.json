{
  "$defs": {
    "RedactionPolicy": {
      "enum": [
        "none",
        "bounded",
        "hash_only"
      ],
      "title": "RedactionPolicy",
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "ephemeral",
        "operational",
        "audit"
      ],
      "title": "RetentionClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "acknowledged_at": {
      "format": "date-time",
      "title": "Acknowledged At",
      "type": "string"
    },
    "acknowledged_by_ref": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Acknowledged By Ref",
      "type": "string"
    },
    "acknowledgement_ref": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Acknowledgement Ref",
      "type": "string"
    },
    "gap_ref": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Gap Ref",
      "type": "string"
    },
    "idempotency_key": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "protocol_version": {
      "const": "state-system.v1",
      "default": "state-system.v1",
      "title": "Protocol Version",
      "type": "string"
    },
    "reason": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "redaction_policy": {
      "$ref": "#/$defs/RedactionPolicy"
    },
    "request_id": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Request Id",
      "type": "string"
    },
    "retain_until": {
      "format": "date-time",
      "title": "Retain Until",
      "type": "string"
    },
    "retention_class": {
      "$ref": "#/$defs/RetentionClass"
    },
    "scope": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scope"
    }
  },
  "required": [
    "idempotency_key",
    "retention_class",
    "retain_until",
    "redaction_policy",
    "acknowledgement_ref",
    "gap_ref",
    "request_id",
    "acknowledged_by_ref",
    "acknowledged_at",
    "reason"
  ],
  "title": "GapAcknowledgement",
  "type": "object"
}
