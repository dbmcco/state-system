{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://state-system.local/schemas/instance-federation-pack.schema.json",
  "title": "InstanceFederationPackRegistry",
  "type": "object",
  "required": ["id", "generated_at", "packs", "invariant"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^instance_federation_pack_registry\\.[a-z0-9_.-]+$"
    },
    "generated_at": { "type": "string" },
    "description": { "type": "string" },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/instance_federation_pack" }
    },
    "invariant": {
      "type": "object",
      "required": [
        "federation_declares_query_boundaries",
        "raw_remote_corpora_not_materialized",
        "freshness_and_gap_policy_visible"
      ],
      "properties": {
        "federation_declares_query_boundaries": { "type": "boolean" },
        "raw_remote_corpora_not_materialized": { "type": "boolean" },
        "freshness_and_gap_policy_visible": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "instance_federation_pack": {
      "type": "object",
      "required": [
        "id",
        "status",
        "federation_mode",
        "local_instance_ref",
        "remote_instance_refs",
        "route_refs",
        "query_surface_refs",
        "tool_action_refs",
        "source_module_refs",
        "identity_boundary",
        "materialization_policy",
        "freshness_policy",
        "output_policy",
        "repair_policy",
        "invariant"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^instance_federation_pack\\.[a-z0-9_.-]+$"
        },
        "description": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["ready", "planned", "gap", "deprecated"]
        },
        "federation_mode": {
          "type": "string",
          "enum": [
            "instance_read",
            "federated_query",
            "source_substrate_query",
            "portfolio_rollup"
          ]
        },
        "local_instance_ref": { "type": "string" },
        "remote_instance_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "remote_instance_ref": { "type": "string" },
        "source_instance_ref": { "type": "string" },
        "route_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "query_surface_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tool_action_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_module_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "identity_boundary": {
          "type": "object",
          "required": ["subject_ref_policy", "entity_ref_policy", "cross_instance_join_policy"],
          "properties": {
            "subject_ref_policy": { "type": "string" },
            "entity_ref_policy": { "type": "string" },
            "cross_instance_join_policy": { "type": "string" },
            "allowed_subject_types": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "materialization_policy": {
          "type": "object",
          "required": ["local_materialization", "allowed_artifact_types", "raw_remote_corpus_policy"],
          "properties": {
            "local_materialization": { "type": "boolean" },
            "allowed_artifact_types": {
              "type": "array",
              "items": { "type": "string" }
            },
            "raw_remote_corpus_policy": { "type": "string" },
            "materialized_summary_policy": { "type": "string" }
          }
        },
        "freshness_policy": {
          "type": "object",
          "required": ["checked_at", "source_watermark", "stale_after", "gap_refs"],
          "properties": {
            "checked_at": { "type": "string" },
            "source_watermark": { "type": "string" },
            "stale_after": { "type": "string" },
            "freshness_status": { "type": "string" },
            "gap_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "subject_note_policy": {
          "type": "object",
          "required": ["applies", "policy"],
          "properties": {
            "applies": { "type": "boolean" },
            "policy": { "type": "string" },
            "allowed_note_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "output_policy": {
          "type": "object",
          "required": ["safe_summary_only", "requires_evidence_refs", "answer_boundary"],
          "properties": {
            "safe_summary_only": { "type": "boolean" },
            "requires_evidence_refs": { "type": "boolean" },
            "answer_boundary": { "type": "string" }
          }
        },
        "repair_policy": {
          "type": "object",
          "required": ["when_unavailable", "when_stale", "owner"],
          "properties": {
            "when_unavailable": { "type": "string" },
            "when_stale": { "type": "string" },
            "owner": { "type": "string" }
          }
        },
        "invariant": {
          "type": "object",
          "required": [
            "pack_authorizes_remote_query_only",
            "pack_does_not_copy_raw_remote_data",
            "gaps_must_be_visible_to_agent"
          ],
          "properties": {
            "pack_authorizes_remote_query_only": { "type": "boolean" },
            "pack_does_not_copy_raw_remote_data": { "type": "boolean" },
            "gaps_must_be_visible_to_agent": { "type": "boolean" }
          }
        }
      }
    }
  }
}
