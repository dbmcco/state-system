{
  "$defs": {
    "RedactionPolicy": {
      "enum": [
        "none",
        "bounded",
        "hash_only"
      ],
      "title": "RedactionPolicy",
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "ephemeral",
        "operational",
        "audit"
      ],
      "title": "RetentionClass",
      "type": "string"
    },
    "StateEffectStatus": {
      "enum": [
        "allowed",
        "denied",
        "failed",
        "queued",
        "committed",
        "skipped"
      ],
      "title": "StateEffectStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "action_ref": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Action Ref"
    },
    "actor_ref": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Actor Ref",
      "type": "string"
    },
    "authorization_ref": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Authorization Ref"
    },
    "entry_ref": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Entry Ref",
      "type": "string"
    },
    "event_type": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Event Type",
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "maxLength": 512,
        "minLength": 3,
        "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "idempotency_key": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "outcome": {
      "$ref": "#/$defs/StateEffectStatus"
    },
    "protocol_version": {
      "const": "state-system.v1",
      "default": "state-system.v1",
      "title": "Protocol Version",
      "type": "string"
    },
    "redaction_policy": {
      "$ref": "#/$defs/RedactionPolicy"
    },
    "request_id": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Request Id",
      "type": "string"
    },
    "retain_until": {
      "format": "date-time",
      "title": "Retain Until",
      "type": "string"
    },
    "retention_class": {
      "$ref": "#/$defs/RetentionClass"
    }
  },
  "required": [
    "idempotency_key",
    "retention_class",
    "retain_until",
    "redaction_policy",
    "entry_ref",
    "request_id",
    "event_type",
    "outcome",
    "occurred_at",
    "actor_ref"
  ],
  "title": "StateAuditLedgerEntry",
  "type": "object"
}
