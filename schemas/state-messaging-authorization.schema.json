{
  "$defs": {
    "RedactionPolicy": {
      "enum": [
        "none",
        "bounded",
        "hash_only"
      ],
      "title": "RedactionPolicy",
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "ephemeral",
        "operational",
        "audit"
      ],
      "title": "RetentionClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Code-issued, short-lived authorization for one messaging effect.",
  "properties": {
    "action_ref": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Action Ref",
      "type": "string"
    },
    "authorization_ref": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Authorization Ref",
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "maxLength": 512,
        "minLength": 3,
        "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "idempotency_key": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "package_ref": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Package Ref",
      "type": "string"
    },
    "protocol_version": {
      "const": "state-system.v1",
      "default": "state-system.v1",
      "title": "Protocol Version",
      "type": "string"
    },
    "recipient_ref": {
      "maxLength": 512,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s]+$",
      "title": "Recipient Ref",
      "type": "string"
    },
    "redaction_policy": {
      "$ref": "#/$defs/RedactionPolicy"
    },
    "request_id": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^\\S+$",
      "title": "Request Id",
      "type": "string"
    },
    "retain_until": {
      "format": "date-time",
      "title": "Retain Until",
      "type": "string"
    },
    "retention_class": {
      "$ref": "#/$defs/RetentionClass"
    }
  },
  "required": [
    "idempotency_key",
    "retention_class",
    "retain_until",
    "redaction_policy",
    "authorization_ref",
    "request_id",
    "action_ref",
    "recipient_ref",
    "issued_at",
    "expires_at",
    "package_ref"
  ],
  "title": "StateMessagingAuthorization",
  "type": "object"
}
