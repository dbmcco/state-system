{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://state-system.local/schemas/agent-memory-entry.schema.json",
  "title": "AgentMemoryEntry",
  "type": "object",
  "required": [
    "id",
    "agent_ref",
    "created_at",
    "memory_key",
    "layer",
    "memory_type",
    "summary",
    "content",
    "confidence",
    "evidence_refs",
    "promotion_status"
  ],
  "properties": {
    "id": { "type": "string" },
    "agent_ref": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "memory_key": { "type": "string" },
    "layer": {
      "type": "string",
      "enum": ["foundation", "active", "searchable", "draft"]
    },
    "memory_type": {
      "type": "string",
      "enum": [
        "identity",
        "preference",
        "pattern",
        "relationship",
        "tooling",
        "domain_observation",
        "working_theory",
        "lesson"
      ]
    },
    "summary": { "type": "string" },
    "content": { "type": "string" },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_state_refs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "promotion_status": {
      "type": "string",
      "enum": ["private", "candidate", "proposed", "promoted", "rejected"]
    },
    "promotion_target_ref": { "type": "string" },
    "review_notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
